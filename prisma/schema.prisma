generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  SUPPLIER
}

enum ProductKind {
  PARENT
  VARIANT
}

enum InventorySyncStatus {
  FRESH
  STALE
  ERROR
}

enum PepperTinyAccountRole {
  MATRIX
  DEPENDENT
}

enum ConversationStatus {
  OPEN
  ARCHIVED
}

enum MessageSenderRole {
  ADMIN
  SUPPLIER
}

enum PepperIaScope {
  ADMIN
  SUPPLIER
}

enum PepperIaMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum ProductSuggestionStatus {
  NEW
  REVIEWING
  NEEDS_REVISION
  APPROVED_FOR_CATALOG
  READY_FOR_CADASTRO
  REJECTED
  IMPORTED_BY_CATALOG
  ARCHIVED
}

enum SuggestionSendStatus {
  NOT_SENT
  SENT
  ERROR
}

enum SuggestionImageType {
  FRONT
  BACK
  EXTRA
}

enum CatalogImageType {
  FRONT
  BACK
  DETAIL
  LIFESTYLE
  OTHER
}

enum MarketplaceListingStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
  ERROR
}

enum SalesOrderStatus {
  OPEN
  APPROVED
  INVOICED
  SHIPPED
  DELIVERED
  CANCELED
  UNKNOWN
}

enum ReplenishmentRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SupplierOrderStatus {
  DRAFT
  AWAITING_SUPPLIER
  SUPPLIER_REVIEWED
  IN_PREPARATION
  PARTIALLY_FULFILLED
  SHIPPED
  NO_STOCK
  CANCELED
}

enum SupplierOrderItemStatus {
  PENDING
  AVAILABLE
  PARTIAL
  NO_STOCK
}

enum OperationalCardOriginType {
  ADMIN_SUPPLIER_ORDER
  REPLENISHMENT_REQUEST
  PRODUCT_SUGGESTION
  MANUAL_FINANCIAL
}

enum SupplierOrderWorkflowStage {
  AWAITING_RESPONSE
  IN_PREPARATION
  SEPARATION_CONFIRMED
  READY_FOR_FINANCIAL
  IN_FINANCIAL_REVIEW
  PAYMENT_PENDING
  PAID
  SHIPPED
  NO_STOCK
  CANCELED
  COMPLETED
}

enum SupplierFinancialEntryType {
  PAYABLE
  RECEIVABLE
}

enum SupplierFinancialEntryStatus {
  DRAFT
  IN_REVIEW
  PENDING_PAYMENT
  PAID
  REJECTED
  CANCELED
}

enum SupplierFinancialAttachmentKind {
  ROMANEIO
  NOTA_FISCAL
  COMPROVANTE
}

model PepperSizeReference {
  code       String   @id
  label      String
  sortOrder  Int
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([active, sortOrder])
}

model PepperColorReference {
  code       String   @id
  label      String
  sortOrder  Int
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([active, sortOrder])
}

model PepperTinyAccountReference {
  key                        String                @id
  label                      String
  role                       PepperTinyAccountRole
  sortOrder                  Int
  active                     Boolean               @default(true)
  sharesGroupStock           Boolean               @default(true)
  readsAvailableMultiCompany Boolean               @default(false)
  handlesCatalogImport       Boolean               @default(false)
  handlesPhysicalStock       Boolean               @default(false)
  zeroBalanceOnCount         Boolean               @default(false)
  salesAffectSharedStock     Boolean               @default(true)
  createdAt                  DateTime              @default(now())
  updatedAt                  DateTime              @updatedAt

  @@index([active, sortOrder])
}

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  role         UserRole
  active       Boolean   @default(true)
  supplierId   String?
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  supplier     Supplier? @relation(fields: [supplierId], references: [id])
  syncRuns     SyncRun[]
  auditLogs    AuditLog[]
  messages     Message[]
  pepperIaThreads PepperIaThread[]
  pepperIaMessages PepperIaMessage[]
  suggestionValidationDrafts SuggestionValidationDraft[]
  createdReplenishmentRequests ReplenishmentRequest[] @relation("CreatedReplenishmentRequests")
  reviewedReplenishmentRequests ReplenishmentRequest[] @relation("ReviewedReplenishmentRequests")
  approvedProductSuggestions ProductSuggestion[] @relation("ApprovedProductSuggestions")
  suggestionStatusHistory ProductSuggestionStatusHistory[]
  createdSupplierOrders SupplierOrder[] @relation("CreatedSupplierOrders")
  updatedSupplierOrders SupplierOrder[] @relation("UpdatedSupplierOrders")
  supplierOrderAttachments SupplierOrderAttachment[]
  supplierOrderStatusHistory SupplierOrderStatusHistory[]
  createdSupplierFinancialEntries SupplierFinancialEntry[] @relation("CreatedSupplierFinancialEntries")
  reviewedSupplierFinancialEntries SupplierFinancialEntry[] @relation("ReviewedSupplierFinancialEntries")
  supplierFinancialAttachments SupplierFinancialAttachment[]
  supplierFinancialStatusHistory SupplierFinancialStatusHistory[]
  supplierOrderWorkflowHistory SupplierOrderWorkflowHistory[]
}

model Supplier {
    id          String            @id @default(cuid())
    name        String
    slug        String            @unique
    logoUrl     String?
    contactName String?
    contactPhone String?
    contactEmail String?
    address     String?
    active      Boolean           @default(true)
    canViewProductValues     Boolean @default(false)
    canViewFinancialDashboard Boolean @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  users       User[]
  assignments ProductSupplier[]
  catalogProducts CatalogProductSupplier[]
  conversations Conversation[]
  suggestions ProductSuggestion[]
  replenishmentRequests ReplenishmentRequest[]
  supplierDailySales SupplierSalesMetricDaily[]
  onboardingItems CatalogOnboardingItem[]
    pepperIaThreads PepperIaThread[]
    suggestionValidationDrafts SuggestionValidationDraft[]
    supplierOrders SupplierOrder[]
    supplierFinancialEntries SupplierFinancialEntry[]
  }

model Customer {
  id                 String      @id @default(cuid())
  tinyContactId      String?     @unique
  externalCode       String?
  name               String
  tradeName          String?
  personType         String?
  document           String?
  stateRegistration  String?
  email              String?
  phone              String?
  mobilePhone        String?
  city               String?
  state              String?
  country            String?
  zipCode            String?
  addressLine        String?
  addressNumber      String?
  addressComplement  String?
  district           String?
  active             Boolean     @default(true)
  customerContextAi  String?
  searchText         String?
  intentTags         String?
  rawPayload         String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  orders             SalesOrder[]

  @@index([email])
  @@index([document])
  @@index([name])
}

model Product {
  id                  String              @id @default(cuid())
  internalName        String
  sku                 String              @unique
  skuParent           String?
  baseCode            String
  quantityCode        String
  sizeCode            String?
  colorCode           String?
  tinyProductId       String?
  tinyVariationId     String?
  tinyCode            String?
  imageUrl            String?
  active              Boolean             @default(true)
  criticalStockThreshold Int?
  lowStockThreshold   Int?
  archivedAt          DateTime?
  kind                ProductKind
  syncStatus          InventorySyncStatus @default(FRESH)
  lastSyncedAt        DateTime?
  fallbackInventory   Int?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  parentId            String?
  parent              Product?            @relation("ProductVariants", fields: [parentId], references: [id])
  variants            Product[]           @relation("ProductVariants")
  assignments         ProductSupplier[]
  inventorySnapshots  InventorySnapshot[]
  salesOrderItems     SalesOrderItem[]
  replenishmentRequests ReplenishmentRequest[]
  supplierOrders      SupplierOrder[]

  @@index([skuParent])
  @@index([baseCode])
}

model ProductSupplier {
  id         String   @id @default(cuid())
  productId   String
  supplierId  String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  product     Product  @relation(fields: [productId], references: [id])
  supplier    Supplier @relation(fields: [supplierId], references: [id])

  @@unique([productId, supplierId])
}

model InventorySnapshot {
  id           String              @id @default(cuid())
  productId     String
  quantity      Int?
  status        InventorySyncStatus @default(FRESH)
  stockBand     String
  source        String              @default("tiny")
  syncedAt      DateTime            @default(now())
  product       Product             @relation(fields: [productId], references: [id])
}

model TinyImportBatch {
  id               String           @id @default(cuid())
  status           String
  startedAt        DateTime         @default(now())
  finishedAt       DateTime?
  notes            String?
  importedByUserId String?
  items            TinyImportItem[]
}

model TinyImportItem {
  id                 String          @id @default(cuid())
  batchId            String
  tinyProductId      String?
  sku                String
  tinyCode           String?
  imageUrl           String?
  rawPayload         String
  selectedForImport  Boolean         @default(false)
  status             String
  errorMessage       String?
  batch              TinyImportBatch @relation(fields: [batchId], references: [id])
}

model TinyWebhookLog {
  id             String   @id @default(cuid())
  webhookType    String
  accountKey     String?
  eventType      String?
  entityType     String?
  entityId       String?
  sku            String?
  tinyProductId  String?
  fingerprint    String?
  duplicateOfId  String?
  status         String
  processingStage String?
  errorMessage   String?
  payload        String
  processedAt    DateTime?
  createdAt      DateTime @default(now())

  @@index([webhookType, createdAt])
  @@index([webhookType, accountKey, createdAt])
  @@index([webhookType, accountKey, fingerprint])
  @@index([entityType, entityId])
  @@index([duplicateOfId])
  @@index([sku])
}

model SyncRun {
  id                String   @id @default(cuid())
  triggerType       String
  scope             String?
  accountKey        String?
  entityType        String?
  entityId          String?
  status            String
  metadata          String?
  startedAt         DateTime @default(now())
  finishedAt        DateTime?
  errorMessage      String?
  requestedByUserId String?
  requestedByUser   User?    @relation(fields: [requestedByUserId], references: [id])

  @@index([scope, startedAt])
  @@index([accountKey, startedAt])
  @@index([entityType, entityId])
}

model SalesOrder {
  id                String           @id @default(cuid())
  tinyOrderId       String           @unique
  tinyContactId     String?
  number            String?
  ecommerceNumber   String?
  channel           String?
  marketplace       String?
  status            SalesOrderStatus @default(UNKNOWN)
  statusLabel       String?
  orderDate         DateTime?
  expectedDate      DateTime?
  invoicedAt        DateTime?
  shippedAt         DateTime?
  deliveredAt       DateTime?
  canceledAt        DateTime?
  totalAmount       Float?
  shippingAmount    Float?
  discountAmount    Float?
  customerId        String?
  customerContextAi String?
  orderContextAi    String?
  rawPayload        String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  customer          Customer?        @relation(fields: [customerId], references: [id])
  items             SalesOrderItem[]
  statusHistory     SalesOrderStatusHistory[]

  @@index([customerId])
  @@index([orderDate])
  @@index([status])
}

model SalesOrderItem {
  id               String          @id @default(cuid())
  salesOrderId     String
  tinyOrderItemId  String?
  sku              String?
  skuParent        String?
  productName      String
  quantity         Int
  unitPrice        Float?
  totalPrice       Float?
  discountAmount   Float?
  variantId        String?
  productId        String?
  salesContextAi   String?
  rawPayload       String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  salesOrder       SalesOrder      @relation(fields: [salesOrderId], references: [id])
  variant          CatalogVariant? @relation(fields: [variantId], references: [id])
  product          Product?        @relation(fields: [productId], references: [id])

  @@index([salesOrderId])
  @@index([sku])
  @@index([variantId])
  @@index([productId])
}

model SalesOrderStatusHistory {
  id             String           @id @default(cuid())
  salesOrderId   String
  status         SalesOrderStatus
  statusLabel    String?
  source         String           @default("tiny")
  changedAt      DateTime         @default(now())
  rawPayload     String?
  salesOrder     SalesOrder       @relation(fields: [salesOrderId], references: [id])

  @@index([salesOrderId, changedAt])
}

model VariantSalesMetricDaily {
  id             String         @id @default(cuid())
  date           DateTime
  variantId      String
  productId      String?
  supplierId     String?
  unitsSold      Int            @default(0)
  grossRevenue   Float          @default(0)
  orderCount     Int            @default(0)
  lastOrderAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  variant        CatalogVariant @relation(fields: [variantId], references: [id])

  @@unique([date, variantId])
  @@index([productId, date])
  @@index([supplierId, date])
}

model ProductSalesMetricDaily {
  id               String         @id @default(cuid())
  date             DateTime
  catalogProductId String
  supplierId       String?
  unitsSold        Int            @default(0)
  grossRevenue     Float          @default(0)
  orderCount       Int            @default(0)
  lastOrderAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  catalogProduct   CatalogProduct @relation(fields: [catalogProductId], references: [id])

  @@unique([date, catalogProductId])
  @@index([supplierId, date])
}

model SupplierSalesMetricDaily {
  id             String    @id @default(cuid())
  date           DateTime
  supplierId     String
  unitsSold      Int       @default(0)
  grossRevenue   Float     @default(0)
  orderCount     Int       @default(0)
  lastOrderAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  supplier       Supplier  @relation(fields: [supplierId], references: [id])

  @@unique([date, supplierId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorUserId String
  action     String
  entityType String
  entityId   String
  metadata   String?
  createdAt  DateTime @default(now())
  actorUser  User     @relation(fields: [actorUserId], references: [id])
}

model Conversation {
  id             String              @id @default(cuid())
  supplierId     String
  status         ConversationStatus  @default(OPEN)
  lastMessageAt  DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  supplier       Supplier            @relation(fields: [supplierId], references: [id])
  messages       Message[]

  @@unique([supplierId])
}

model Message {
  id             String            @id @default(cuid())
  conversationId String
  senderUserId   String
  senderRole     MessageSenderRole
  body           String
  referenceType  String?
  referenceId    String?
  referenceTitle String?
  referenceSubtitle String?
  referenceHref  String?
  referenceBadge String?
  referenceMetaJson String?
  readAt         DateTime?
  createdAt      DateTime          @default(now())
  conversation   Conversation      @relation(fields: [conversationId], references: [id])
  senderUser     User              @relation(fields: [senderUserId], references: [id])
  attachments    MessageAttachment[]

  @@index([conversationId, createdAt])
}

model MessageAttachment {
  id         String   @id @default(cuid())
  messageId   String
  fileName   String
  fileUrl    String
  mimeType   String?
  sizeBytes  Int?
  createdAt  DateTime @default(now())
  message    Message  @relation(fields: [messageId], references: [id])
}

model PepperIaThread {
  id         String              @id @default(cuid())
  scope      PepperIaScope
  userId     String
  supplierId String?
  title      String              @default("PepperIA")
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  user       User                @relation(fields: [userId], references: [id])
  supplier   Supplier?           @relation(fields: [supplierId], references: [id])
  messages   PepperIaMessage[]

  @@index([userId, scope])
  @@index([supplierId, scope])
}

model PepperIaMessage {
  id          String               @id @default(cuid())
  threadId    String
  userId      String
  role        PepperIaMessageRole
  body        String
  metadata    String?
  createdAt   DateTime             @default(now())
  thread      PepperIaThread       @relation(fields: [threadId], references: [id])
  user        User                 @relation(fields: [userId], references: [id])

  @@index([threadId, createdAt])
}

model SuggestionValidationDraft {
  id          String   @id @default(cuid())
  userId      String
  supplierId  String
  payloadJson String
  resultJson  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
  supplier    Supplier @relation(fields: [supplierId], references: [id])

  @@index([userId, createdAt])
  @@index([supplierId, createdAt])
}

model ProductSuggestion {
  id                   String                   @id @default(cuid())
  supplierId           String
  status               ProductSuggestionStatus  @default(NEW)
  tinySendStatus       SuggestionSendStatus     @default(NOT_SENT)
  tinySentAt           DateTime?
  tinySendError        String?
  productName          String
  price                Float
  material             String
  modelDescription     String
  adminDraftName       String?
  adminDraftPrice      Float?
  adminDraftMaterial   String?
  adminDraftModel      String?
  generatedCatalogJson String?
  notes                String?
  internalReviewNote   String?
  supplierVisibleNote  String?
  approvedAt           DateTime?
  approvedByUserId     String?
  revisionRequestedAt  DateTime?
  rejectedAt           DateTime?
  importedAt           DateTime?
  importedBy           String?
  revisionCount        Int                      @default(0)
  processedAt          DateTime?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  supplier             Supplier                 @relation(fields: [supplierId], references: [id])
  approvedByUser       User?                    @relation("ApprovedProductSuggestions", fields: [approvedByUserId], references: [id])
  images               ProductSuggestionImage[]
  sizes                ProductSuggestionSize[]
  colors               ProductSuggestionColor[]
  statusHistory        ProductSuggestionStatusHistory[]
  onboardingItem       CatalogOnboardingItem?
}

model ProductSuggestionStatusHistory {
  id               String                  @id @default(cuid())
  suggestionId     String
  fromStatus       ProductSuggestionStatus?
  toStatus         ProductSuggestionStatus
  note             String?
  visibleToSupplier Boolean                @default(false)
  actorUserId      String?
  createdAt        DateTime                @default(now())
  suggestion       ProductSuggestion       @relation(fields: [suggestionId], references: [id])
  actorUser        User?                   @relation(fields: [actorUserId], references: [id])

  @@index([suggestionId, createdAt])
}

model CatalogOnboardingItem {
  id                    String            @id @default(cuid())
  suggestionId          String            @unique
  supplierId            String
  productName           String
  price                 Float
  material              String
  modelDescription      String
  sizesJson             String
  colorsJson            String
  imagesJson            String
  supplierName          String
  supplierVisibleNote   String?
  internalReviewNote    String?
  generatedCatalogJson  String?
  readyForCatalogAt     DateTime         @default(now())
  importedAt            DateTime?
  importedBy            String?
  status                String           @default("READY")
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  suggestion            ProductSuggestion @relation(fields: [suggestionId], references: [id])
  supplier              Supplier         @relation(fields: [supplierId], references: [id])

  @@index([status, readyForCatalogAt])
  @@index([supplierId])
}

model ProductSuggestionImage {
  id           String             @id @default(cuid())
  suggestionId String
  type         SuggestionImageType
  fileName     String
  fileUrl      String
  mimeType     String?
  sizeBytes    Int?
  sortOrder    Int                @default(0)
  createdAt    DateTime           @default(now())
  suggestion   ProductSuggestion  @relation(fields: [suggestionId], references: [id])
}

model ProductSuggestionSize {
  id           String             @id @default(cuid())
  suggestionId String
  label        String
  code         String?
  createdAt    DateTime           @default(now())
  suggestion   ProductSuggestion  @relation(fields: [suggestionId], references: [id])
}

model ProductSuggestionColor {
  id           String             @id @default(cuid())
  suggestionId String
  label        String
  code         String?
  createdAt    DateTime           @default(now())
  suggestion   ProductSuggestion  @relation(fields: [suggestionId], references: [id])
}

model ReplenishmentRequest {
  id               String                     @id @default(cuid())
  supplierId       String
  createdByUserId  String
  reviewedByUserId String?
  productId        String?
  productName      String
  productSku       String
  imageUrl         String?
  note             String?
  htmlContent      String
  status           ReplenishmentRequestStatus @default(PENDING)
  reviewedAt       DateTime?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  supplier         Supplier                   @relation(fields: [supplierId], references: [id])
  createdByUser    User                       @relation("CreatedReplenishmentRequests", fields: [createdByUserId], references: [id])
  reviewedByUser   User?                      @relation("ReviewedReplenishmentRequests", fields: [reviewedByUserId], references: [id])
  product          Product?                   @relation(fields: [productId], references: [id])
  items            ReplenishmentRequestItem[]

  @@index([supplierId, status, createdAt])
  @@index([productSku])
}

model ReplenishmentRequestItem {
  id                     String               @id @default(cuid())
  replenishmentRequestId String
  sku                    String
  size                   String
  color                  String
  currentStock           Int?
  requestedQuantity      Int
  createdAt              DateTime             @default(now())
  replenishmentRequest   ReplenishmentRequest @relation(fields: [replenishmentRequestId], references: [id])

  @@index([replenishmentRequestId])
}

model SupplierOrder {
    id                 String              @id @default(cuid())
    supplierId         String
    createdByUserId    String
    updatedByUserId    String?
    orderNumber        String              @unique
    status             SupplierOrderStatus @default(AWAITING_SUPPLIER)
    workflowStage      SupplierOrderWorkflowStage @default(AWAITING_RESPONSE)
    originType         OperationalCardOriginType  @default(ADMIN_SUPPLIER_ORDER)
    originReferenceId  String?
    productId          String?
    productName        String
    productSku         String
    imageUrl           String?
    adminNote          String?
    supplierNote       String?
    supplierHasNoStock Boolean             @default(false)
    expectedShipDate   DateTime?
    separationConfirmedAt DateTime?
    sentToFinancialAt  DateTime?
    paidAt             DateTime?
    completedAt        DateTime?
    respondedAt        DateTime?
    shippedAt          DateTime?
    estimatedTotalCost Float               @default(0)
    confirmedTotalCost Float               @default(0)
    createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  supplier           Supplier            @relation(fields: [supplierId], references: [id])
  createdByUser      User                @relation("CreatedSupplierOrders", fields: [createdByUserId], references: [id])
  updatedByUser      User?               @relation("UpdatedSupplierOrders", fields: [updatedByUserId], references: [id])
    product            Product?            @relation(fields: [productId], references: [id])
    items              SupplierOrderItem[]
    attachments        SupplierOrderAttachment[]
    statusHistory      SupplierOrderStatusHistory[]
    workflowHistory    SupplierOrderWorkflowHistory[]
    financialEntry     SupplierFinancialEntry?

    @@index([supplierId, status, createdAt])
    @@index([supplierId, workflowStage, createdAt])
    @@index([productId])
  }

model SupplierOrderItem {
  id                 String                  @id @default(cuid())
  supplierOrderId    String
  catalogVariantId   String?
  sku                String
  productName        String
  color              String
  size               String
  requestedQuantity  Int
  fulfilledQuantity  Int                     @default(0)
  itemStatus         SupplierOrderItemStatus @default(PENDING)
  unitCost           Float                   @default(0)
  confirmedUnitCost  Float?
  requestedTotalCost Float                   @default(0)
  confirmedTotalCost Float                   @default(0)
  supplierItemNote   String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  supplierOrder      SupplierOrder           @relation(fields: [supplierOrderId], references: [id])
  catalogVariant     CatalogVariant?         @relation(fields: [catalogVariantId], references: [id])

  @@index([supplierOrderId])
  @@index([catalogVariantId])
  @@index([sku])
}

model SupplierOrderAttachment {
  id               String        @id @default(cuid())
  supplierOrderId  String
  uploadedByUserId String
  kind             String        @default("ROMANEIO")
  fileName         String
  fileUrl          String
  mimeType         String?
  sizeBytes        Int?
  createdAt        DateTime      @default(now())
  supplierOrder    SupplierOrder @relation(fields: [supplierOrderId], references: [id])
  uploadedByUser   User          @relation(fields: [uploadedByUserId], references: [id])

  @@index([supplierOrderId, createdAt])
}

model SupplierOrderStatusHistory {
  id                String              @id @default(cuid())
  supplierOrderId   String
  fromStatus        SupplierOrderStatus?
  toStatus          SupplierOrderStatus
  note              String?
  visibleToSupplier Boolean             @default(true)
  actorUserId       String?
  createdAt         DateTime            @default(now())
  supplierOrder     SupplierOrder       @relation(fields: [supplierOrderId], references: [id])
  actorUser         User?               @relation(fields: [actorUserId], references: [id])

    @@index([supplierOrderId, createdAt])
  }

model SupplierOrderWorkflowHistory {
    id              String                    @id @default(cuid())
    supplierOrderId String
    fromStage       SupplierOrderWorkflowStage?
    toStage         SupplierOrderWorkflowStage
    note            String?
    actorUserId     String?
    createdAt       DateTime                  @default(now())
    supplierOrder   SupplierOrder             @relation(fields: [supplierOrderId], references: [id])
    actorUser       User?                     @relation(fields: [actorUserId], references: [id])

    @@index([supplierOrderId, createdAt])
  }

model SupplierFinancialEntry {
    id               String                      @id @default(cuid())
    supplierId       String
    supplierOrderId  String                      @unique
    createdByUserId  String
    reviewedByUserId String?
    entryType        SupplierFinancialEntryType  @default(PAYABLE)
    status           SupplierFinancialEntryStatus @default(DRAFT)
    originType       OperationalCardOriginType   @default(ADMIN_SUPPLIER_ORDER)
    originReferenceId String?
    title            String
    productName      String
    productSku       String
    imageUrl         String?
    amount           Float                       @default(0)
    note             String?
    supplierNote     String?
    dueDate          DateTime?
    submittedAt      DateTime?
    reviewedAt       DateTime?
    paidAt           DateTime?
    createdAt        DateTime                    @default(now())
    updatedAt        DateTime                    @updatedAt
    supplier         Supplier                    @relation(fields: [supplierId], references: [id])
    supplierOrder    SupplierOrder               @relation(fields: [supplierOrderId], references: [id])
    createdByUser    User                        @relation("CreatedSupplierFinancialEntries", fields: [createdByUserId], references: [id])
    reviewedByUser   User?                       @relation("ReviewedSupplierFinancialEntries", fields: [reviewedByUserId], references: [id])
    attachments      SupplierFinancialAttachment[]
    statusHistory    SupplierFinancialStatusHistory[]

    @@index([supplierId, status, createdAt])
    @@index([originType, originReferenceId])
  }

model SupplierFinancialAttachment {
    id                     String                       @id @default(cuid())
    supplierFinancialEntryId String
    uploadedByUserId       String
    kind                   SupplierFinancialAttachmentKind @default(ROMANEIO)
    fileName               String
    fileUrl                String
    mimeType               String?
    sizeBytes              Int?
    createdAt              DateTime                     @default(now())
    supplierFinancialEntry SupplierFinancialEntry       @relation(fields: [supplierFinancialEntryId], references: [id])
    uploadedByUser         User                         @relation(fields: [uploadedByUserId], references: [id])

    @@index([supplierFinancialEntryId, createdAt])
  }

model SupplierFinancialStatusHistory {
    id                     String                      @id @default(cuid())
    supplierFinancialEntryId String
    fromStatus             SupplierFinancialEntryStatus?
    toStatus               SupplierFinancialEntryStatus
    note                   String?
    actorUserId            String?
    createdAt              DateTime                    @default(now())
    supplierFinancialEntry SupplierFinancialEntry      @relation(fields: [supplierFinancialEntryId], references: [id])
    actorUser              User?                       @relation(fields: [actorUserId], references: [id])

    @@index([supplierFinancialEntryId, createdAt])
  }

model CatalogProduct {
  id                String                     @id @default(cuid())
  sourceProductId   String?                    @unique
  skuParent         String                     @unique
  baseCode          String
  quantityCode      String
  name              String
  brand             String?
  categoryPath      String?
  material          String?
  composition       String?
  gender            String?
  model             String?
  style             String?
  descriptionShort  String?
  descriptionLong   String?
  availableSizes    String?
  availableColors   String?
  salesContextAi    String?
  searchText        String?
  intentTags        String?
  tinyProductId     String?
  tinyCode          String?
  mainImageUrl      String?
  active            Boolean                    @default(true)
  archivedAt        DateTime?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  variants          CatalogVariant[]
  images            CatalogImage[]
  listings          CatalogMarketplaceListing[]
  attributes        CatalogAttribute[]
  tinyMappings      CatalogTinyMapping[]
  supplierLinks     CatalogProductSupplier[]
  salesMetricsDaily ProductSalesMetricDaily[]

  @@index([baseCode])
  @@index([active])
}

model CatalogVariant {
  id                String              @id @default(cuid())
  catalogProductId  String
  sourceProductId   String?             @unique
  sku               String              @unique
  quantityCode      String
  sizeCode          String?
  sizeLabel         String?
  colorCode         String?
  colorLabel        String?
  barcode           String?
  salesContextAi    String?
  searchText        String?
  intentTags        String?
  tinyProductId     String?
  tinyCode          String?
  active            Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  catalogProduct    CatalogProduct      @relation(fields: [catalogProductId], references: [id])
  inventory         CatalogInventory?
  price             CatalogPrice?
  images            CatalogImage[]
  attributes        CatalogAttribute[]
  tinyMappings      CatalogTinyMapping[]
  salesOrderItems   SalesOrderItem[]
  salesMetricsDaily VariantSalesMetricDaily[]
  supplierOrderItems SupplierOrderItem[]

  @@index([catalogProductId])
  @@index([sizeCode, colorCode])
}

model CatalogInventory {
  id                          String              @id @default(cuid())
  catalogVariantId            String              @unique
  availableMultiCompanyStock  Int?
  stockStatus                 String?
  inventorySyncStatus         InventorySyncStatus @default(STALE)
  lastStockSyncAt             DateTime?
  source                      String              @default("tiny")
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt
  catalogVariant              CatalogVariant      @relation(fields: [catalogVariantId], references: [id])
}

model CatalogPrice {
  id                String         @id @default(cuid())
  catalogVariantId  String         @unique
  salePrice         Float?
  promotionalPrice  Float?
  costPrice         Float?
  currency          String         @default("BRL")
  source            String         @default("internal")
  syncedAt          DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  catalogVariant    CatalogVariant @relation(fields: [catalogVariantId], references: [id])
}

model CatalogImage {
  id                String          @id @default(cuid())
  catalogProductId  String?
  catalogVariantId  String?
  imageType         CatalogImageType @default(OTHER)
  url               String
  altText           String?
  isPrimary         Boolean         @default(false)
  sortOrder         Int             @default(0)
  source            String          @default("internal")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  catalogProduct    CatalogProduct? @relation(fields: [catalogProductId], references: [id])
  catalogVariant    CatalogVariant? @relation(fields: [catalogVariantId], references: [id])

  @@index([catalogProductId, sortOrder])
  @@index([catalogVariantId, sortOrder])
}

model CatalogMarketplaceListing {
  id                String                  @id @default(cuid())
  catalogProductId  String
  marketplace       String
  externalListingId String
  title             String
  permalink         String?
  status            MarketplaceListingStatus @default(DRAFT)
  listingPrice      Float?
  promotionalPrice  Float?
  currency          String                  @default("BRL")
  lastSyncedAt      DateTime?
  rawPayload        String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  catalogProduct    CatalogProduct          @relation(fields: [catalogProductId], references: [id])

  @@unique([marketplace, externalListingId])
  @@index([catalogProductId])
}

model CatalogAttribute {
  id                String          @id @default(cuid())
  catalogProductId  String?
  catalogVariantId  String?
  attributeKey      String
  attributeValue    String
  source            String          @default("internal")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  catalogProduct    CatalogProduct? @relation(fields: [catalogProductId], references: [id])
  catalogVariant    CatalogVariant? @relation(fields: [catalogVariantId], references: [id])

  @@index([attributeKey])
  @@index([catalogProductId])
  @@index([catalogVariantId])
}

model CatalogTinyMapping {
  id                String          @id @default(cuid())
  accountKey        String          @default("pepper")
  entityType        String
  catalogProductId  String?
  catalogVariantId  String?
  sku               String
  tinyId            String
  tinyParentId      String?
  tinyCode          String?
  rawPayload        String?
  lastSyncAt        DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  catalogProduct    CatalogProduct? @relation(fields: [catalogProductId], references: [id])
  catalogVariant    CatalogVariant? @relation(fields: [catalogVariantId], references: [id])

  @@unique([accountKey, entityType, sku])
  @@index([catalogProductId])
  @@index([catalogVariantId])
  @@index([accountKey, tinyId])
}

model CatalogProductSupplier {
  id                String         @id @default(cuid())
  catalogProductId  String
  supplierId        String
  active            Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  catalogProduct    CatalogProduct @relation(fields: [catalogProductId], references: [id])
  supplier          Supplier       @relation(fields: [supplierId], references: [id])

  @@unique([catalogProductId, supplierId])
}
