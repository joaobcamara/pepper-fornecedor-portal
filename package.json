{
  "name": "fornecedor-portal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3000",
    "prebuild": "prisma generate",
    "build": "next build",
    "build:guarded": "node scripts/guarded-build.mjs",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "typecheck": "tsc --noEmit",
    "doctor:deploy": "node scripts/deploy-doctor.mjs",
    "release:check": "node scripts/deploy-doctor.mjs && node scripts/guarded-build.mjs",
    "smoke:foundation": "tsx scripts/foundation-smoke-check.ts",
    "smoke:collab": "node scripts/run-foundation-collab-smoke.mjs",
    "smoke:http": "node scripts/http-smoke-runner.mjs",
    "foundation:live-check": "tsx scripts/foundation-live-check.ts",
    "foundation:apply": "tsx scripts/apply-foundation-structure.ts",
    "foundation:references:sync": "tsx scripts/sync-pepper-references.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "catalog:sync": "tsx prisma/catalog-sync.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "next": "^15.3.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "prisma": "^6.7.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
